{
    admin off
}

:$PORT {
    # Root directory for static files - dist is at root level
    root * ./dist
    
    # Enable compression
    encode gzip zstd br
    
    # SPA routing - fallback to index.html
    try_files {path} /index.html
    
    # Serve static files
    file_server
    
    # Log errors for debugging
    log {
        output stderr
        level DEBUG
    }
}